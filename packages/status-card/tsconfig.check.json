{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "./dist",
    "noEmit": true,
    "declaration": false,
    "declarationMap": false,
    "sourceMap": false,
    "moduleResolution": "bundler",
    "paths": {
      "@hmip/panel-api": ["../panel-api/src/index.ts"],
      "@hmip/schedule-core": ["../schedule-core/src/index.ts"],
      "@hmip/schedule-ui": ["../schedule-ui/src/index.ts"]
    }
  },
  "include": [
    "src/**/*.ts",
    "../climate-schedule-card/src/**/*.ts",
    "../schedule-card/src/**/*.ts"
  ],
  "exclude": ["node_modules", "dist"]
}
